{
  "name": "@memograph/desktop",
  "version": "0.1.0",
  "description": "MemoGraph Desktop Application",
  "main": "dist/main/index.js",
  "author": "rememo",
  "productName": "rememo",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "type-check": "tsc --noEmit",
    "build:win": "npm run build && electron-builder --win --x64 --publish never",
    "build:win32": "npm run build && electron-builder --win --ia32 --publish never",
    "build:win-all": "npm run build && electron-builder --win --x64 --ia32 --publish never",
    "build:mac": "npm run build && electron-builder --mac --arm64 --publish never",
    "build:mac-x64": "npm run build && electron-builder --mac --x64 --publish never",
    "build:mac-universal": "npm run build && electron-builder --mac --universal --publish never",
    "dist": "npm run build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.rememo.desktop",
    "productName": "rememo",
    "publish": null,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "build/icon.png",
      "build/icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "rememo"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "build/icon.png",
      "build/icon.ico"
    ]
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.5",
    "@types/better-sqlite3": "^7.6.13",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "d3-force": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "43.0.0",
    "electron-builder": "^26.0.0",
    "sharp": "^0.35.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
